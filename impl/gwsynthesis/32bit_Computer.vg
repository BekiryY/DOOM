module CPU_Registers (
  write_enable,
  ddr_user_clk,
  write_addr,
  write_data,
  read1_addr,
  read2_addr,
  read1_data,
  read2_data
)
;
input write_enable;
input ddr_user_clk;
input [4:0] write_addr;
input [31:0] write_data;
input [4:0] read1_addr;
input [4:0] read2_addr;
output [31:0] read1_data;
output [31:0] read2_data;
wire write_en_gated;
wire write_en_gated_4;
wire VCC;
wire GND;
  LUT4 write_en_gated_s0 (
    .F(write_en_gated),
    .I0(write_addr[0]),
    .I1(write_addr[1]),
    .I2(write_en_gated_4),
    .I3(write_enable) 
);
defparam write_en_gated_s0.INIT=16'hEF00;
  LUT3 write_en_gated_s1 (
    .F(write_en_gated_4),
    .I0(write_addr[2]),
    .I1(write_addr[3]),
    .I2(write_addr[4]) 
);
defparam write_en_gated_s1.INIT=8'h01;
  Gowin_SDPB regfile_port1 (
    .ddr_user_clk(ddr_user_clk),
    .write_en_gated(write_en_gated),
    .write_data(write_data[31:0]),
    .write_addr(write_addr[4:0]),
    .read1_addr(read1_addr[4:0]),
    .read1_data(read1_data[31:0])
);
  Gowin_SDPB_0 regfile_port2 (
    .ddr_user_clk(ddr_user_clk),
    .write_en_gated(write_en_gated),
