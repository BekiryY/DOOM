module Main_Computer (
  sys_clk,
  sys_rst_n,
  MISO,
  PS2_DATA_I,
  PS2_CLK_I,
  PS2_DATA_DEBUG,
  PS2_CLK_DEBUG,
  RX,
  TX,
  MOSI,
  SPI_CS,
  SPI_CLK,
  debug_cs,
  debug_clk,
  debug_mosi,
  debug_miso,
  ddr_addr,
  ddr_bank,
  ddr_cs,
  ddr_ras,
  ddr_cas,
  ddr_we,
  ddr_ck,
  ddr_ck_n,
  ddr_cke,
  ddr_odt,
  ddr_reset_n,
  ddr_dm,
  ddr_dq,
  ddr_dqs,
  ddr_dqs_n,
  tmds_clk_p,
  tmds_clk_n,
  tmds_data_p,
  tmds_data_n
)
;
input sys_clk;
input sys_rst_n;
input MISO;
input PS2_DATA_I;
input PS2_CLK_I;
output PS2_DATA_DEBUG;
output PS2_CLK_DEBUG;
input RX;
output TX;
output MOSI;
output SPI_CS;
output SPI_CLK;
output debug_cs;
output debug_clk;
output debug_mosi;
output debug_miso;
output [13:0] ddr_addr;
output [2:0] ddr_bank;
output ddr_cs;
output ddr_ras;
output ddr_cas;
output ddr_we;
output ddr_ck;
output ddr_ck_n;
output ddr_cke;
output ddr_odt;
output ddr_reset_n;
output [1:0] ddr_dm;
inout [15:0] ddr_dq;
inout [1:0] ddr_dqs;
inout [1:0] ddr_dqs_n;
output tmds_clk_p;
output tmds_clk_n;
output [2:0] tmds_data_p;
output [2:0] tmds_data_n;
