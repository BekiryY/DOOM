module DDR3_Memory_Interface_Top (
  ddr_cmd_en,
  ddr_cmd_en_11,
  ddr_cmd_en_10,
  ddr_wr_data_en,
  sys_clk_d,
  ddr_memory_clk,
  sys_rst_n_d,
  n315_3,
  user_addr,
  ddr_cmd,
  ddr_wr_data,
  ddr_wr_data_mask,
  ddr_cmd_ready,
  ddr_wr_data_rdy,
  ddr_rd_data_valid,
  ddr_user_clk,
  n838_6,
  ddr_ck,
  ddr_ck_n,
  ddr_reset_n,
  ddr_cs,
  ddr_ras,
  ddr_cas,
  ddr_we,
  ddr_cke,
  ddr_odt,
  ddr_calib_complete,
  ddr_dm,
  ddr_addr,
  ddr_bank,
  ddr_rd_data,
  ddr_dqs,
  ddr_dqs_n,
  ddr_dq
)
;
input ddr_cmd_en;
input ddr_cmd_en_11;
input ddr_cmd_en_10;
input ddr_wr_data_en;
input sys_clk_d;
input ddr_memory_clk;
input sys_rst_n_d;
input n315_3;
input [26:1] user_addr;
input [0:0] ddr_cmd;
input [127:0] ddr_wr_data;
input [15:0] ddr_wr_data_mask;
output ddr_cmd_ready;
output ddr_wr_data_rdy;
output ddr_rd_data_valid;
output ddr_user_clk;
output n838_6;
output ddr_ck;
output ddr_ck_n;
output ddr_reset_n;
output ddr_cs;
output ddr_ras;
output ddr_cas;
output ddr_we;
output ddr_cke;
output ddr_odt;
output ddr_calib_complete;
output [1:0] ddr_dm;
output [13:0] ddr_addr;
output [2:0] ddr_bank;
output [127:0] ddr_rd_data;
inout [1:0] ddr_dqs;
inout [1:0] ddr_dqs_n;
inout [15:0] ddr_dq;
wire VCC;
wire GND;
  \~GW_DDR3_PHY_MC.DDR3_Memory_Interface_Top  gw3_top (
    .ddr_cmd_en(ddr_cmd_en),
    .ddr_cmd_en_11(ddr_cmd_en_11),
    .ddr_cmd_en_10(ddr_cmd_en_10),
