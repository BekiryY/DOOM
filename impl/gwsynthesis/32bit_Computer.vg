module Gowin_SDPB (
  ddr_user_clk,
  write_en_gated,
  write_data,
  write_addr,
  read1_addr,
  read1_data
)
;
input ddr_user_clk;
input write_en_gated;
input [31:0] write_data;
input [4:0] write_addr;
input [4:0] read1_addr;
output [31:0] read1_data;
wire VCC;
wire GND;
  SDPB sdpb_inst_0 (
    .DO(read1_data[31:0]),
    .DI(write_data[31:0]),
    .BLKSELA({GND,GND,GND}),
    .BLKSELB({GND,GND,GND}),
    .ADA({GND,GND,GND,GND,write_addr[4:0],GND,VCC,VCC,VCC,VCC}),
    .ADB({GND,GND,GND,GND,read1_addr[4:0],GND,GND,GND,GND,GND}),
    .CLKA(ddr_user_clk),
    .CLKB(ddr_user_clk),
    .CEA(write_en_gated),
    .CEB(VCC),
    .OCE(VCC),
    .RESETA(GND),
    .RESETB(GND) 
);
defparam sdpb_inst_0.BIT_WIDTH_0=32;
defparam sdpb_inst_0.BIT_WIDTH_1=32;
defparam sdpb_inst_0.BLK_SEL_0=3'b000;
defparam sdpb_inst_0.BLK_SEL_1=3'b000;
defparam sdpb_inst_0.READ_MODE=1'b0;
defparam sdpb_inst_0.RESET_MODE="SYNC";
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* Gowin_SDPB */
