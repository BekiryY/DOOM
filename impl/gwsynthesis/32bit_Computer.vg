`pragma protect end_protected
module DDR3_Memory_Interface_Top (
  ddr_cmd_en,
  ddr_wr_data_en,
  sys_clk_d,
  ddr_memory_clk,
  sys_rst_n_d,
  n315_3,
  user_addr,
  ddr_cmd,
  ddr_wr_data,
  ddr_wr_data_mask,
  ddr_cmd_ready,
  ddr_wr_data_rdy,
  ddr_rd_data_valid,
  ddr_user_clk,
  n838_6,
  ddr_ck,
  ddr_ck_n,
  ddr_reset_n,
  ddr_cs,
  ddr_ras,
  ddr_cas,
  ddr_we,
  ddr_cke,
  ddr_odt,
  ddr_calib_complete,
  ddr_dm,
  ddr_addr,
  ddr_bank,
  ddr_rd_data,
  ddr_dqs,
  ddr_dqs_n,
  ddr_dq
)
;
input ddr_cmd_en;
input ddr_wr_data_en;
input sys_clk_d;
input ddr_memory_clk;
input sys_rst_n_d;
input n315_3;
input [26:1] user_addr;
input [0:0] ddr_cmd;
input [127:0] ddr_wr_data;
input [15:0] ddr_wr_data_mask;
output ddr_cmd_ready;
output ddr_wr_data_rdy;
output ddr_rd_data_valid;
