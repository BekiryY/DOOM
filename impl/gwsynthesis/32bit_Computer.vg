    .user_addr(user_addr[26:1]),
    .ddr_cmd(ddr_cmd[0]),
    .ddr_wr_data(ddr_wr_data[127:0]),
    .ddr_wr_data_mask(ddr_wr_data_mask[15:0]),
    .ddr_cmd_ready(ddr_cmd_ready),
    .ddr_wr_data_rdy(ddr_wr_data_rdy),
    .ddr_rd_data_valid(ddr_rd_data_valid),
    .ddr_user_clk(ddr_user_clk),
    .n838_6(n838_6),
    .ddr_ck(ddr_ck),
    .ddr_ck_n(ddr_ck_n),
    .ddr_reset_n(ddr_reset_n),
    .ddr_cs(ddr_cs),
    .ddr_ras(ddr_ras),
    .ddr_cas(ddr_cas),
    .ddr_we(ddr_we),
    .ddr_cke(ddr_cke),
    .ddr_odt(ddr_odt),
    .ddr_calib_complete(ddr_calib_complete),
    .ddr_dm(ddr_dm[1:0]),
    .ddr_addr(ddr_addr[13:0]),
    .ddr_bank(ddr_bank[2:0]),
    .ddr_rd_data(ddr_rd_data[127:0]),
